#!/usr/bin/perl
use strict;
use warnings;
my @L = ("m64_all_Fa_cov.txt", "m64_all_Mo_cov.txt");
my $step = 200;
local *IN;
for my $file (@L) {
  open IN, $file or die "Can't read $file : $!";
  while ( <IN> ) {
    my @F = split /\t/;
    next if $F[0] eq "id";
    next if $F[1] < 1000000;
    my @C = split /;/, $F[16];
    my $start;
    my $wasZero;
    for my $p (0 .. $#C) {
      my $v = $C[$p];
      if ($v == 0) {
	if (defined $start) {
	  $wasZero = $p unless defined $wasZero;
	}
      } else {
	if (defined $start) {
	  if (defined $wasZero) {
	    # we have a zero region here
	    printf "%s\t%u\t%u\t%u\n", $F[0], $F[1], $wasZero * $step + 1, ($p - 1) * $step;
	    undef $wasZero;
	  }
	} else {
	  $start = $p;
	}
      }
    }
  }
  close IN;
}
exit 0;
__END__
