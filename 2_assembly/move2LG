#!/usr/bin/perl
use strict;
use warnings;
my $tbl = "/scratch/tyto/TableCorespondance.txt";
my %G;
local *IN;
open IN, $tbl or die " Can't read $tbl : $!";
while ( <IN> ) {
  my @F = split /\t/;
  $G{$F[0]} = $F[2];
}
close IN;
my @L = glob "aln/{Fa,Mo}_*";
for my $file (@L) {
  my ($id) = $file =~ /^aln\/(.._[^_]+)_/;
  die "grmp $file" unless defined $id;
  my $gr = $G{$id};
  next unless defined $gr;
  next if $gr eq "NA";
  $gr = "0$gr" if $gr < 10;
  $gr = "LG$gr";
  my $to = $file;
  $to =~ s/^aln\//aln\/$gr\//;
  mkdir "aln/$gr" unless -d "aln/$gr";
  rename $file, $to or die "Can't rename $file to $to : $!";
  #print STDERR "$file -> $to\n";
}
exit 0;
__END__
