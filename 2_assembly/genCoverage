#!/usr/bin/perl
use strict;
use warnings;
my $map = "/home/iseli/tyto/m64_all_tab_map_MoFa_reclassify.txt";
my %P;
my %CL;
local *IN;
open IN, $map or die "Can't read $map : $!";
while ( <IN> ) {
  my @F = split /\t/;
  $P{$F[0]} = $F[7];
  $CL{$F[0]} = $F[2];
}
close IN;
# increase for LR on ON
#my $tl = 500;
my $tl = 1500;
my $step = 200;
my $cut = 2000;
my $minHigh = 40;
my $maxLow = 20;
my %C = ("Father" => 0, "Mother" => 0, "Unknown" => 0, "centromers" => 0, "kinetochores" => 0, "musat" => 0, "other" => 0, "telomers" => 0);
my $cur;
my $len;
print join("\t","id","len","start","end","chimera","high1","low","high2","Father","Mother","Unknown","centromers","kinetochores","musat","other","telomers","cov"), "\n";
while ( <> ) {
  # could look for overhangs at the beginning and at the end
  my @F = split /\t/;
  if (defined($cur) and $cur ne $F[5]) {
    &process;
    %C = ("Father" => 0, "Mother" => 0, "Unknown" => 0, "centromers" => 0, "kinetochores" => 0, "musat" => 0, "other" => 0, "telomers" => 0);
    undef $cur;
    undef $len;
  }
  unless (defined $cur) {
    $cur = $F[5];
    $len = $F[6];
  }
  next if $F[2] > $tl or ($F[1] - $F[3]) > $tl;
  my $p1 = int(($F[7] + $cut)/$step);
  my $p2 = int(($F[8] - $cut)/$step);
  next if $p2 <= $p1;
  my $id = substr $F[0], 0, 8;
  if (defined($P{$id}) and defined($CL{$id})) {
    $C{$P{$id}} += 1;
    $C{$CL{$id}} += 1;
  } else {
    $C{"Unknown"} += 1;
    $C{"other"} += 1;
  }
  for my $p ($p1 .. $p2) {
    $C{$p} += 1;
  }
}
&process if defined $cur;
exit 0;

sub process {
  my $max = int($len/$step);
  my @A;
  my $start;
  my $end;
  my $chimera;
  my $high1;
  my $low;
  my $high2;
  my $wasZero;
  for my $p (0 .. $max) {
    my $v = 0;
    $v = $C{$p} if defined $C{$p};
    push @A, $v;
    if ($v == 0) {
      if (defined $start) {
	$wasZero = $p unless defined $wasZero;
	if (not defined $end) {
	  $end = $p - 1 if $p > 0;
	}
      }
    } else {
      undef $end;
      if (defined $start) {
	if (defined $wasZero) {
	  $chimera = $wasZero unless defined $chimera;
	}
	if ($v >= $minHigh) {
	  $high1 = $p unless defined $high1;
	  if (defined $low) {
	    $high2 = $p unless defined $high2;
	  }
	} elsif ($v <= $maxLow) {
	  if (defined $high1) {
	    $low = $p unless defined $low;
	  }
	}
      } else {
	$start = $p;
      }
    }
  }
  print join("\t",$cur,$len);
  for my $i ($start, $end, $chimera, $high1, $low, $high2) {
    if (defined $i) {
      print "\t", $i * $step + 1;
    } else {
      print "\tNA";
    }
  }
  for my $e ("Father","Mother","Unknown","centromers","kinetochores","musat","other","telomers") {
    print "\t", $C{$e};
  }
  print "\t", join(";",@A), "\n";
}
