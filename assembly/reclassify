#!/usr/bin/perl
use strict;
use warnings;
my $chunk = 30000;
my %C;
my $map = "m64_all_tab_map_MoFa_contig_gfa.txt";
my $pval = "/home/nguex/GOUDET/allele_sort/20240419/HiFi_ReadParentSelection_v2.txt";
local *IN;
open IN, $map or die "Can't read $map : $!";
my %H;
while ( <IN> ) {
  s/\s+$//s;
  my @F = split /\t/;
  if ($F[0] eq "id") {
    for my $i (0 .. $#F) {
      $H{$F[$i]} = $i;
    }
    next
  }
  for my $j ($H{'Fatctg'}, $H{'Motctg'}) {
    next if $F[$j] eq "NA";
    my $p1 = int($F[$j+2] / $chunk);
    my $p2 = int(($F[$j+2] + $F[$H{'len'}]) / $chunk);
    if ($p2 > $p1) {
      $C{$F[$j]} = [] unless defined $C{$F[$j]};
      $C{$F[$j]}->[$p2] = { 'Father' => [ 0, [] ], 'Mother' => [ 0, [] ], 'Unknown' => [ 0, [] ] } unless defined $C{$F[$j]}->[$p2];
      $C{$F[$j]}->[$p2]->{$F[$H{'parent'}]}->[0] += 1;
      push @{$C{$F[$j]}->[$p2]->{$F[$H{'parent'}]}->[1]}, $F[0];
    }
  }
}
close IN;
my %P;
open IN, $pval or die "Can't read $pval : $!";
while ( <IN> ) {
  s/^#//;
  s/\s+$//s;
  my @F = split /\t/;
  next if $F[0] eq "id";
  my $parent = $F[2];
  $parent = $F[6] if $parent eq "Unknown";
  $P{$F[0]} = [ $parent, $F[3] ];
}
close IN;
open IN, $map or die "Can't read $map : $!";
my %RR;
while ( <IN> ) {
  my @F = split /\t/;
  if ($F[0] eq "id") {
    splice @F, $H{'parent'} + 1, 0, "reclassify";
    print join("\t", @F);
    next
  }
  my $imbalanced;
  my %R;
  for my $j ($H{'Fatctg'}, $H{'Motctg'}) {
    next if $F[$j] eq "NA";
    my $p1 = int($F[$j+2] / $chunk);
    my $p2 = int(($F[$j+2] + $F[$H{'len'}]) / $chunk);
    if ($p2 > $p1) {
      for my $r (@{$C{$F[$j]}->[$p2]->{'Father'}->[1]}, @{$C{$F[$j]}->[$p2]->{'Mother'}->[1]}, @{$C{$F[$j]}->[$p2]->{'Unknown'}->[1]}) {
	$R{$r} = 1;
      }
      my $fa = $C{$F[$j]}->[$p2]->{'Father'}->[0];
      my $mo = $C{$F[$j]}->[$p2]->{'Mother'}->[0];
      my $unk = $C{$F[$j]}->[$p2]->{'Unknown'}->[0];
      my $tot = $fa + $mo + $unk;
      my $totP = $tot;
      if (defined $C{$F[$j]}->[$p2-1]) {
	$totP = $C{$F[$j]}->[$p2-1]->{'Father'}->[0] + $C{$F[$j]}->[$p2-1]->{'Mother'}->[0] + $C{$F[$j]}->[$p2-1]->{'Unknown'}->[0];
      }
      my $totN = $tot;
      if (defined $C{$F[$j]}->[$p2+1]) {
	$totN = $C{$F[$j]}->[$p2+1]->{'Father'}->[0] + $C{$F[$j]}->[$p2+1]->{'Mother'}->[0] + $C{$F[$j]}->[$p2+1]->{'Unknown'}->[0];
      }
      # Meh...
      $imbalanced = 1 if ($tot >= 70 or $totN >= 70 or $totP >= 70) and ($fa / $tot < 0.2 or $mo / $tot < 0.2);
    }
  }
  if (defined $imbalanced) {
    unless (defined $RR{$F[0]}) {
      my @A = sort { $P{$a}->[0] cmp $P{$b}->[0] || ($P{$a}->[0] eq "Father" ? $P{$a}->[1] <=> $P{$b}->[1] : $P{$b}->[1] <=> $P{$a}->[1]) } (keys %R);
      print STDERR "Sorting for $F[0]\n";
      my $mid = int(($#A+1) / 2);
      for my $i (0 .. $#A) {
	$RR{$A[$i]} = $i < $mid ? "Father" : "Mother";
	printf STDERR "  %u\t%s\t%s\t%s\t%s\n", $i, $A[$i], $RR{$A[$i]}, $P{$A[$i]}->[0], $P{$A[$i]}->[1];
      }
    }
    splice @F, $H{'parent'} + 1, 0, $RR{$F[0]};
  } else {
    splice @F, $H{'parent'} + 1, 0, $F[$H{'parent'}];
  }
  print join("\t", @F);
}
close IN;
exit 0;
__END__
