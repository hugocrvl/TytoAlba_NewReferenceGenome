#!/usr/bin/perl
use strict;
use warnings;
local *FD;
local *OUT;
my $minlen = 300000;
mkdir "aln" unless -d "aln";
my $ta = "/tmp/chris/a.fa";
my $tb = "/tmp/chris/b.fa";
my $format = "general:nmismatch,length1,name1,size1,strand1,start1,end1,name2,size2,strand2,start2,end2,text1,diff,text2";
for my $p ( "Fa", "Mo" ) {
  my %P;
  my $paf = "$p.0518.vs.$p.paf";
  open FD, $paf or die "Can't read $paf : $!";
  while ( <FD> ) {
    my @F = split /\t/;
    next if $F[3]-$F[2] < $minlen;
    my $pair = "$F[5]\t$F[0]";
    $P{$pair} = 1;
  }
  close FD;
  my $curLG;
  for my $pair (sort keys %P) {
    my ($lg, $ptg) = split /\t/, $pair;
    print STDERR "Processing $lg vs $ptg";
    my $of = "aln/$lg.$ptg.aln";
    if (not defined($curLG) or $curLG ne $lg) {
      $curLG = $lg;
      #system "zgrep -A 1 $lg all_$p.fa.gz >$ta";
      system "fetch -c /scratch/tyto/fetch.conf ctg:$lg >$ta";
      die "Failed to retrieve $lg" unless -s $ta;
    }
    system "grep -A 1 $ptg /data2/chris/tyto/hifiasm.$p/asm.p_ctg.fa >$tb";
    die "Failed to retrieve $ptg" unless -s $tb;
    open FD, "lastz --ambiguous=n --step=10 --seed=match15 --notransition --exact=501 --chain --allocate:traceback=2G ‑‑format=$format $ta $tb |" or die "Can't launch lastz : $!";
    open OUT, ">$of" or die "Can't create $of : $!";
    my $cnt = 0;
    while ( <FD> ) {
      if (/^#/) {
	print OUT $_;
	next;
      }
      my @F = split /\t/;
      next if $F[1] < $minlen;
      print OUT $_;
      $cnt += 1;
    }
    close OUT;
    close FD;
    print STDERR " ==> $cnt alignments >= $minlen\n";
    unlink $of if $cnt == 0;
  }
}
exit 0;
__END__
