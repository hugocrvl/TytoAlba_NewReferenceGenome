#!/usr/bin/perl
use strict;
use warnings;
my $tl = 500;
my $cut = 2000;
local *IN;
while ( <> ) {
  my @P = split;
  my $file = "ON_" . substr($P[0],0,2) . ".paf";
  open IN, "grep $P[0] $file |" or die "Can't grep entry : $!";
  my $empty = 1;
  while ( <IN> ) {
    my @F = split /\t/;
    next if $F[2] > $tl or ($F[1] - $F[3]) > $tl;
    next if $P[2] - $cut < $F[7];
    next if $P[3] + $cut > $F[8];
    my $start = $P[2] - ($cut * 2) - $F[7] + $F[2];
    $start = 1 if $start < 1;
    my $end = $P[3] + ($cut * 2) - $F[7] + $F[2];
    $end = $F[1] if $end > $F[1];
    if ($F[4] eq "-") {
      my $tem = $end;
      $end = $F[1] - $start + 1;
      $start = $F[1] - $tem + 1;
    }
    my $tag = sprintf "ON:%s[%u..%u]", $F[0], $start, $end;
    printf "%s\t%u\t%u\t%u\t%s\t%u\t%u\t%u\t%s\t%u\t%u\t%s\n", @P[0..3], @F[0..4,7,8], $tag;
    undef $empty;
  }
  printf "%s\t%u\t%u\t%u\tNA\tNA\tNA\tNA\tNA\tNA\tNA\tNA\n", @P[0..3] if defined $empty;
}
exit 0;
__END__
